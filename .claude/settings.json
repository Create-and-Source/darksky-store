{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-opus-4-6",

  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(pip install *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(curl *)",
      "Bash(aws s3 ls *)",
      "Bash(aws s3 cp *)",
      "Bash(aws cloudformation describe*)",
      "Bash(aws ecs describe*)",
      "Bash(aws ecs list*)",
      "Bash(aws logs *)",
      "Bash(docker build *)",
      "Bash(docker compose up *)",
      "Bash(docker compose down *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)",
      "Bash(render *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(jq *)",
      "Bash(echo *)",
      "Bash(env *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(date *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(npm publish *)",
      "Bash(docker push *)",
      "Bash(aws deploy *)",
      "Bash(aws cloudformation create*)",
      "Bash(aws cloudformation update*)",
      "Bash(aws cloudformation delete*)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(rm *)"
    ],
    "deny": []
  },

  "plansDirectory": "./docs/plans",

  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "NODE_ENV": "development"
  }
}
